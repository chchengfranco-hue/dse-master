{
  "name": "WritingModel",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title or essay prompt label"
    },
    "topic": {
      "type": "string",
      "description": "Main topic category"
    },
    "subtopic": {
      "type": "string",
      "description": "Sub-topic"
    },
    "image_url": {
      "type": "string",
      "description": "Optional image URL"
    },
    "exam_ref": {
      "type": "string",
      "description": "Past exam paper reference (e.g. 2023 DSE Paper 2 Q3)"
    },
    "genre": {
      "type": "string",
      "description": "Writing genre (matches a WritingTemplate genre name)"
    },
    "question": {
      "type": "string",
      "description": "The exam question or writing prompt"
    },
    "content": {
      "type": "string",
      "description": "The model essay or writing content"
    },
    "annotations": {
      "type": "object",
      "description": "Key-value map of word annotations (word: meaning)"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published"
      ],
      "default": "published",
      "description": "Draft = only visible to editors; Published = visible to all students"
    },
    "is_published": {
      "type": "boolean",
      "default": true,
      "description": "Legacy field \u2014 kept for backward compatibility"
    }
  },
  "required": [
    "title",
    "content"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "data.is_published": true
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}